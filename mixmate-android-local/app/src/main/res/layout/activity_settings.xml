<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#1d1d1f">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hostname of IP-adres"
        android:textColor="#aeaeb2"
        android:textSize="12sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/fieldHost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="mixmate.local of 192.168.1.x"
        android:inputType="textUri"
        android:background="@drawable/field_bg"
        android:padding="14dp"
        android:textColor="#ffffff"
        android:textColorHint="#6e6e73"
        android:textSize="15sp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Poort"
        android:textColor="#aeaeb2"
        android:textSize="12sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/fieldPort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="8000"
        android:inputType="number"
        android:background="@drawable/field_bg"
        android:padding="14dp"
        android:textColor="#ffffff"
        android:textColorHint="#6e6e73"
        android:textSize="15sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Als mixmate.local niet werkt, voer het IP-adres van de Pi in (te vinden in je router)."
        android:textColor="#6e6e73"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Opslaan en verbinden"
        android:textSize="15sp"
        android:textColor="#1d1d1f"
        android:backgroundTint="#ffffff"
        android:stateListAnimator="@null" />

</LinearLayout>
