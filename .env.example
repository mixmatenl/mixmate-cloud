# Kopieer dit bestand naar .env en vul in

# Verplicht: willekeurige geheime sleutel (genereer op https://randomkeygen.com → 256-bit)
JWT_SECRET=vervang_dit_met_een_lange_geheime_sleutel

# Geheim wachtwoord voor admin endpoints (alleen voor jou)
ADMIN_SECRET=kies_een_sterk_admin_wachtwoord

# Eerste account dat automatisch aangemaakt wordt bij opstart
ADMIN_EMAIL=jouw@email.nl
ADMIN_PASSWORD=kies_een_wachtwoord
